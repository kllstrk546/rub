APP_NAME=rub-rate-bot
LOG_LEVEL=INFO
START_POLLING=true

DATABASE_URL=sqlite+aiosqlite:///./rub_rate_bot.db

TELEGRAM_BOT_TOKEN=
# BOT_TOKEN= is also supported as an alias for TELEGRAM_BOT_TOKEN.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELETHON_SESSION_NAME=rub_rate_bot

NOBITEX_SOURCE=@nobitexprices
RAPIRA_SOURCE=@USDT_Rapira_bot
MARGIN_PERCENT=3.56
AUTO_NOTIFY_ADMINS_ON_PARSE_ERROR=false
RATE_REFRESH_MODE=aligned_5min
RATE_REFRESH_EVERY_MINUTES=5
RATE_REFRESH_DELAY_SECONDS=15
FETCH_LAST_MESSAGES_LIMIT=10
